{
  "ConnectionStrings": {
    "DefaultConnection": "DataSource=/data/plannit.db;Cache=Shared"
  },
  "DataProtection": {
    "KeyPath": "/data/keys"
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "TrustProxyNetwork": false,
    "KnownProxies": [ "127.0.0.1", "::1" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowRegistration": false
}
