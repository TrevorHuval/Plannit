{
  "ConnectionStrings": {
    "DefaultConnection": "DataSource=/data/plannit.db;Cache=Shared"
  },
  "DataProtection": {
    "KeyPath": "/data/keys"
  },
  "ForwardedHeaders": {
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowRegistration": false
}
