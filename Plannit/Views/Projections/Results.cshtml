@model Plannit.Models.ViewModels.ScenarioResultsViewModel
@{
    ViewData["Title"] = Model.ScenarioName + " — Results";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@Model.ScenarioName</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.ScenarioId" class="btn btn-outline-secondary">Edit Assumptions</a>
        <a asp-action="Index" class="btn btn-outline-secondary">All Scenarios</a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle text-muted mb-2">Balance at Retirement (Age @Model.RetirementAge)</h6>
                <h3 class="text-primary">@Model.Result.RetirementBalance.ToString("C0")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle text-muted mb-2">
                    @(Model.Result.DepletionAge.HasValue ? "Money Runs Out" : "Surplus at Death")
                </h6>
                <h3 class="@(Model.Result.DepletionAge.HasValue ? "text-danger" : "text-success")">
                    @if (Model.Result.DepletionAge.HasValue)
                    {
                        @:Age @Model.Result.DepletionAge
                    }
                    else
                    {
                        @Model.Result.SurplusAtDeath.ToString("C0")
                    }
                </h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle text-muted mb-2">Safe Spending (4% Rule)</h6>
                <h3>@Model.Result.SafeSpendingEstimate.ToString("C0")<small class="text-muted">/yr</small></h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle text-muted mb-2">Planned Spending</h6>
                <h3>@Model.AnnualRetirementSpending.ToString("C0")<small class="text-muted">/yr</small></h3>
            </div>
        </div>
    </div>
</div>

@{
    var verdict = Model.Result.DepletionAge.HasValue
        ? $"At this rate, your money runs out at age {Model.Result.DepletionAge}. Consider reducing spending, increasing contributions, or delaying retirement."
        : $"Your plan looks sustainable through age {Model.LifeExpectancy} with an estimated {Model.Result.SurplusAtDeath.ToString("C0")} remaining.";
    var verdictClass = Model.Result.DepletionAge.HasValue ? "alert-warning" : "alert-success";
}
<div class="alert @verdictClass mb-4">
    <strong>Verdict:</strong> @verdict
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Projected Balances by Account Over Time</h5>
    </div>
    <div class="card-body">
        <canvas id="projectionChart" height="400"></canvas>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Year-by-Year Detail</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light" style="position: sticky; top: 0;">
                    <tr>
                        <th>Age</th>
                        <th>Year</th>
                        @foreach (var acct in Model.Accounts)
                        {
                            <th class="text-end">@acct.Name</th>
                        }
                        <th class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var snap in Model.Result.YearlySnapshots)
                    {
                        var isRetirement = snap.Age == Model.RetirementAge;
                        <tr class="@(isRetirement ? "table-info" : "")">
                            <td>@snap.Age</td>
                            <td>@snap.Year</td>
                            @foreach (var acct in Model.Accounts)
                            {
                                <td class="text-end">@snap.AccountBalances.GetValueOrDefault(acct.Id).ToString("C0")</td>
                            }
                            <td class="text-end fw-bold">@snap.TotalBalance.ToString("C0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var snapshots = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Result.YearlySnapshots.Select(s => new {
                    age = s.Age,
                    year = s.Year,
                    balances = s.AccountBalances,
                    total = s.TotalBalance
                })));

            var accounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Accounts.Select(a => new { id = a.Id, name = a.Name })));

            var colors = [
                'rgba(78, 121, 167, 0.7)',
                'rgba(242, 142, 43, 0.7)',
                'rgba(89, 161, 79, 0.7)',
                'rgba(225, 87, 89, 0.7)',
                'rgba(118, 183, 178, 0.7)',
                'rgba(237, 201, 72, 0.7)',
                'rgba(176, 122, 161, 0.7)',
                'rgba(156, 117, 95, 0.7)'
            ];

            var borderColors = colors.map(c => c.replace('0.7', '1'));

            var datasets = accounts.map(function (acct, i) {
                return {
                    label: acct.name,
                    data: snapshots.map(function (s) { return s.balances[acct.id] || 0; }),
                    backgroundColor: colors[i % colors.length],
                    borderColor: borderColors[i % borderColors.length],
                    borderWidth: 1,
                    fill: true
                };
            });

            var retirementAge = @Model.RetirementAge;
            var retirementIdx = snapshots.findIndex(s => s.age === retirementAge);

            new Chart(document.getElementById('projectionChart'), {
                type: 'line',
                data: {
                    labels: snapshots.map(s => 'Age ' + s.age),
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function (ctx) {
                                    return ctx.dataset.label + ': $' + ctx.parsed.y.toLocaleString(undefined, { maximumFractionDigits: 0 });
                                },
                                footer: function (tooltipItems) {
                                    var total = tooltipItems.reduce((a, b) => a + b.parsed.y, 0);
                                    return 'Total: $' + total.toLocaleString(undefined, { maximumFractionDigits: 0 });
                                }
                            }
                        },
                        annotation: retirementIdx >= 0 ? {
                            annotations: {
                                retirementLine: {
                                    type: 'line',
                                    xMin: retirementIdx,
                                    xMax: retirementIdx,
                                    borderColor: '#dc3545',
                                    borderWidth: 2,
                                    borderDash: [6, 6],
                                    label: {
                                        content: 'Retirement',
                                        enabled: true,
                                        position: 'start'
                                    }
                                }
                            }
                        } : {}
                    },
                    scales: {
                        x: {
                            ticks: {
                                maxTicksLimit: 15,
                                callback: function (value, index) {
                                    return snapshots[index].age % 5 === 0 ? 'Age ' + snapshots[index].age : '';
                                }
                            }
                        },
                        y: {
                            stacked: true,
                            beginAtZero: true,
                            ticks: {
                                callback: function (value) {
                                    if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                                    if (value >= 1000) return '$' + (value / 1000).toFixed(0) + 'K';
                                    return '$' + value;
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}
