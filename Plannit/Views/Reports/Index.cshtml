@model Plannit.Models.ViewModels.ReportsViewModel
@{
    ViewData["Title"] = "Reports";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Spending Reports</h1>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label mb-0 small text-muted">Presets</label>
                <div class="btn-group" role="group">
                    @{
                        var presets = new[] {
                            ("thisMonth", "This Month"),
                            ("lastMonth", "Last Month"),
                            ("last3Months", "Last 3 Months"),
                            ("ytd", "Year to Date"),
                            ("last12Months", "Last 12 Months"),
                            ("allTime", "All Time")
                        };
                    }
                    @foreach (var (value, label) in presets)
                    {
                        var isActive = Model.Preset == value;
                        <a href="?preset=@value"
                           class="btn btn-sm @(isActive ? "btn-primary" : "btn-outline-secondary")">@label</a>
                    }
                </div>
            </div>
            <div class="col-auto">
                <label for="startDate" class="form-label mb-0 small text-muted">From</label>
                <input type="date" name="startDate" id="startDate" class="form-control form-control-sm" style="width:auto"
                       value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto">
                <label for="endDate" class="form-label mb-0 small text-muted">To</label>
                <input type="date" name="endDate" id="endDate" class="form-control form-control-sm" style="width:auto"
                       value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Apply</button>
            </div>
            <div class="col-auto ms-2">
                <div class="btn-group" role="group">
                    <a href="?startDate=@Model.StartDate.ToString("yyyy-MM-dd")&endDate=@Model.EndDate.ToString("yyyy-MM-dd")&nav=prev"
                       class="btn btn-sm btn-outline-secondary">&laquo; Prev</a>
                    <a href="?startDate=@Model.StartDate.ToString("yyyy-MM-dd")&endDate=@Model.EndDate.ToString("yyyy-MM-dd")&nav=next"
                       class="btn btn-sm btn-outline-secondary">Next &raquo;</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle text-muted mb-2">Income</h6>
                <h3 class="text-success">@Model.IncomeExpense.Income.ToString("C")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle text-muted mb-2">Expenses</h6>
                <h3 class="text-danger">@Model.IncomeExpense.Expenses.ToString("C")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle text-muted mb-2">Net</h6>
                <h3 class="@(Model.IncomeExpense.Net >= 0 ? "text-success" : "text-danger")">@Model.IncomeExpense.Net.ToString("C")</h3>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Spending by Category &mdash; @Model.DateRangeLabel</h5>
            </div>
            <div class="card-body">
                @if (Model.SpendByCategory.Categories.Any())
                {
                    <canvas id="categoryChart" height="300"></canvas>
                }
                else
                {
                    <p class="text-muted">No spending data for this period.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Monthly Spending &mdash; Trailing 12 Months</h5>
            </div>
            <div class="card-body">
                @if (Model.MonthlyHistory.Any(m => m.Total > 0))
                {
                    <canvas id="monthlyChart" height="300"></canvas>
                }
                else
                {
                    <p class="text-muted">No spending history available.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Category Breakdown</h5>
                <span class="badge bg-secondary">Total: @Model.SpendByCategory.TotalSpend.ToString("C")</span>
            </div>
            <div class="card-body p-0">
                @if (Model.SpendByCategory.Categories.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Category</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-end">%</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cat in Model.SpendByCategory.Categories)
                                {
                                    var pct = Model.SpendByCategory.TotalSpend > 0
                                        ? (cat.Total / Model.SpendByCategory.TotalSpend * 100)
                                        : 0;
                                    <tr>
                                        <td>@cat.CategoryName</td>
                                        <td class="text-end">@cat.Total.ToString("C")</td>
                                        <td class="text-end">@pct.ToString("F1")%</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted p-3">No spending data for this period.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Top Merchants &mdash; @Model.DateRangeLabel</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.TopMerchants.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Merchant</th>
                                    <th class="text-end">Transactions</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in Model.TopMerchants)
                                {
                                    <tr>
                                        <td>@m.MerchantName</td>
                                        <td class="text-end">@m.TransactionCount</td>
                                        <td class="text-end">@m.Total.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted p-3">No transactions for this period.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var categoryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.SpendByCategory.Categories.Select(c => new { label = c.CategoryName, value = c.Total })));

            if (categoryData.length > 0) {
                var colors = [
                    '#4e79a7', '#f28e2b', '#e15759', '#76b7b2', '#59a14f',
                    '#edc948', '#b07aa1', '#ff9da7', '#9c755f', '#bab0ac',
                    '#86bcb6', '#8cd17d', '#b6992d'
                ];
                new Chart(document.getElementById('categoryChart'), {
                    type: 'doughnut',
                    data: {
                        labels: categoryData.map(d => d.label),
                        datasets: [{
                            data: categoryData.map(d => d.value),
                            backgroundColor: categoryData.map((_, i) => colors[i % colors.length])
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'right', labels: { boxWidth: 12 } },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        var total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                                        var pct = ((ctx.parsed / total) * 100).toFixed(1);
                                        return ctx.label + ': $' + ctx.parsed.toLocaleString(undefined, { minimumFractionDigits: 2 }) + ' (' + pct + '%)';
                                    }
                                }
                            }
                        }
                    }
                });
            }

            var monthlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.MonthlyHistory.Select(m => new { label = m.Label, value = m.Total })));

            if (monthlyData.some(d => d.value > 0)) {
                new Chart(document.getElementById('monthlyChart'), {
                    type: 'bar',
                    data: {
                        labels: monthlyData.map(d => d.label),
                        datasets: [{
                            label: 'Spending',
                            data: monthlyData.map(d => d.value),
                            backgroundColor: '#4e79a7'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function (value) { return '$' + value.toLocaleString(); }
                                }
                            }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        return '$' + ctx.parsed.y.toLocaleString(undefined, { minimumFractionDigits: 2 });
                                    }
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
}
