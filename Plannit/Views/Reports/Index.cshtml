@model Plannit.Models.ViewModels.ReportsViewModel
@{
    ViewData["Title"] = "Reports";
}

<div class="page-header">
    <h1>Spending Reports</h1>
</div>

<div class="pl-filter-bar mb-4">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label">Presets</label>
            <div class="btn-group" role="group">
                @{
                    var presets = new[] {
                        ("thisMonth", "This Month"),
                        ("lastMonth", "Last Month"),
                        ("last3Months", "Last 3 Mo"),
                        ("ytd", "YTD"),
                        ("last12Months", "12 Mo"),
                        ("allTime", "All Time")
                    };
                }
                @foreach (var (value, label) in presets)
                {
                    var isActive = Model.Preset == value;
                    <a href="?preset=@value"
                       class="btn btn-sm @(isActive ? "btn-primary" : "btn-outline-secondary")">@label</a>
                }
            </div>
        </div>
        <div class="col-auto">
            <label for="startDate" class="form-label">From</label>
            <input type="date" name="startDate" id="startDate" class="form-control form-control-sm" style="width:auto"
                   value="@Model.StartDate.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-auto">
            <label for="endDate" class="form-label">To</label>
            <input type="date" name="endDate" id="endDate" class="form-control form-control-sm" style="width:auto"
                   value="@Model.EndDate.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-sm btn-primary">Apply</button>
        </div>
        <div class="col-auto ms-2">
            <div class="btn-group" role="group">
                <a href="?startDate=@Model.StartDate.ToString("yyyy-MM-dd")&endDate=@Model.EndDate.ToString("yyyy-MM-dd")&nav=prev"
                   class="btn btn-sm btn-outline-secondary"><i class="bi bi-chevron-left"></i> Prev</a>
                <a href="?startDate=@Model.StartDate.ToString("yyyy-MM-dd")&endDate=@Model.EndDate.ToString("yyyy-MM-dd")&nav=next"
                   class="btn btn-sm btn-outline-secondary">Next <i class="bi bi-chevron-right"></i></a>
            </div>
        </div>
    </form>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="pl-stat-card">
                <div class="stat-label">Income</div>
                <div class="stat-value positive">@Model.IncomeExpense.Income.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="pl-stat-card">
                <div class="stat-label">Expenses</div>
                <div class="stat-value negative">@Model.IncomeExpense.Expenses.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="pl-stat-card">
                <div class="stat-label">Net</div>
                <div class="stat-value @(Model.IncomeExpense.Net >= 0 ? "positive" : "negative")">@Model.IncomeExpense.Net.ToString("C")</div>
            </div>
        </div>
    </div>
</div>

@if (Model.TransfersSanity.TransactionCount > 0)
{
    if (Model.TransfersSanity.HasUnpairedSuspects)
    {
        <div class="alert alert-warning mb-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    <text>@Model.TransfersSanity.UnpairedSuspects.Count unpaired card payment(s) totaling @Model.TransfersSanity.UnpairedSuspectTotal.ToString("C") for @Model.DateRangeLabel &mdash; the matching leg on the other account is missing or miscategorized.</text>
                </div>
            </div>
            <ul class="list-unstyled mb-0 mt-2 small">
                @foreach (var suspect in Model.TransfersSanity.UnpairedSuspects)
                {
                    <li>
                        <a asp-controller="Transactions" asp-action="Edit" asp-route-id="@suspect.TransactionId">
                            @suspect.Date.ToString("MMM d") &mdash; @suspect.AccountName &mdash; @suspect.Description
                        </a>
                        <span class="pl-num @(suspect.Amount < 0 ? "text-negative" : "text-positive")">@suspect.Amount.ToString("C")</span>
                    </li>
                }
            </ul>
        </div>
    }
    else
    {
        <div class="alert alert-success mb-3">
            <i class="bi bi-check-circle me-1"></i>
            <text>All inter-account transfers pair up for @Model.DateRangeLabel &mdash; @Model.TransfersSanity.PairedTransactionCount transaction(s) matched.</text>
        </div>
    }

    @if (Model.TransfersSanity.ExternalTransfersCount > 0)
    {
        <div class="alert alert-info mb-4">
            <i class="bi bi-info-circle me-1"></i>
            <text>External transfers for @Model.DateRangeLabel (Venmo, Zelle, and other transfers outside tracked accounts): @Model.TransfersSanity.ExternalTransfersOut.ToString("C") out / @Model.TransfersSanity.ExternalTransfersIn.ToString("C") in across @Model.TransfersSanity.ExternalTransfersCount transaction(s). These never pair &mdash; informational only.</text>
        </div>
    }
}

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Spending by Category &mdash; @Model.DateRangeLabel</h5>
            </div>
            <div class="card-body">
                @if (Model.SpendByCategory.Categories.Any())
                {
                    <div class="pl-chart-container">
                        <canvas id="categoryChart" height="300"></canvas>
                    </div>
                }
                else
                {
                    <p class="text-muted">No spending data for this period.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Monthly Spending &mdash; Trailing 12 Months</h5>
            </div>
            <div class="card-body">
                @if (Model.MonthlyHistory.Any(m => m.Total > 0))
                {
                    <div class="pl-chart-container">
                        <canvas id="monthlyChart" height="300"></canvas>
                    </div>
                }
                else
                {
                    <p class="text-muted">No spending history available.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Category Breakdown</h5>
                <span class="badge bg-secondary">Total: @Model.SpendByCategory.TotalSpend.ToString("C")</span>
            </div>
            @if (Model.SpendByCategory.Categories.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th class="text-end">Amount</th>
                                <th class="text-end">%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cat in Model.SpendByCategory.Categories)
                            {
                                var pct = Model.SpendByCategory.TotalSpend > 0
                                    ? (cat.Total / Model.SpendByCategory.TotalSpend * 100)
                                    : 0;
                                <tr>
                                    <td>@cat.CategoryName</td>
                                    <td class="text-end">@cat.Total.ToString("C")</td>
                                    <td class="text-end text-muted">@pct.ToString("F1")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="card-body">
                    <p class="text-muted">No spending data for this period.</p>
                </div>
            }
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Top Merchants &mdash; @Model.DateRangeLabel</h5>
            </div>
            @if (Model.TopMerchants.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Merchant</th>
                                <th class="text-end">Transactions</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.TopMerchants)
                            {
                                <tr>
                                    <td>@m.MerchantName</td>
                                    <td class="text-end">@m.TransactionCount</td>
                                    <td class="text-end">@m.Total.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="card-body">
                    <p class="text-muted">No transactions for this period.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.umd.min.js"></script>
    <script>
        (function () {
            var c = PlChart.getColors();
            var palette = PlChart.palette;
            var categoryChart, monthlyChart;

            var categoryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.SpendByCategory.Categories.Select(c => new { label = c.CategoryName, value = c.Total })));

            if (categoryData.length > 0) {
                categoryChart = new Chart(document.getElementById('categoryChart'), {
                    type: 'doughnut',
                    data: {
                        labels: categoryData.map(function (d) { return d.label; }),
                        datasets: [{
                            data: categoryData.map(function (d) { return d.value; }),
                            backgroundColor: categoryData.map(function (_, i) { return palette[i % palette.length]; })
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: { boxWidth: 12, color: c.textMuted }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        var total = ctx.dataset.data.reduce(function (a, b) { return a + b; }, 0);
                                        var pct = ((ctx.parsed / total) * 100).toFixed(1);
                                        return ctx.label + ': $' + ctx.parsed.toLocaleString(undefined, { minimumFractionDigits: 2 }) + ' (' + pct + '%)';
                                    }
                                }
                            }
                        }
                    }
                });
            }

            var monthlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.MonthlyHistory.Select(m => new { label = m.Label, value = m.Total })));

            if (monthlyData.some(function (d) { return d.value > 0; })) {
                monthlyChart = new Chart(document.getElementById('monthlyChart'), {
                    type: 'bar',
                    data: {
                        labels: monthlyData.map(function (d) { return d.label; }),
                        datasets: [{
                            label: 'Spending',
                            data: monthlyData.map(function (d) { return d.value; }),
                            backgroundColor: c.primary
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: PlChart.defaultScaleOptions(),
                            y: Object.assign(PlChart.defaultScaleOptions(), {
                                beginAtZero: true,
                                ticks: {
                                    color: c.textMuted,
                                    callback: function (value) { return '$' + value.toLocaleString(); }
                                }
                            })
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        return '$' + ctx.parsed.y.toLocaleString(undefined, { minimumFractionDigits: 2 });
                                    }
                                }
                            }
                        }
                    }
                });
            }

            document.addEventListener('themechanged', function () {
                var nc = PlChart.getColors();
                if (categoryChart) {
                    categoryChart.options.plugins.legend.labels.color = nc.textMuted;
                    categoryChart.update('none');
                }
                if (monthlyChart) {
                    monthlyChart.data.datasets[0].backgroundColor = nc.primary;
                    PlChart.applyTheme(monthlyChart);
                }
            });
        })();
    </script>
}
