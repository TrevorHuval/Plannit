@model Plannit.Models.ViewModels.BillIndexViewModel
@{
    ViewData["Title"] = "Bills";
}

<div class="page-header">
    <h1>Bills</h1>
    <div class="page-actions">
        <a asp-controller="Bills" asp-action="Calendar" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-calendar3 me-1"></i>Calendar
        </a>
        <a asp-controller="Bills" asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Add Bill
        </a>
    </div>
</div>

@if (TempData["Success"] is not null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Bills.Any())
{
    <div class="card">
        <div class="pl-empty-state">
            <div class="empty-icon"><i class="bi bi-receipt"></i></div>
            <h4>No bills tracked yet</h4>
            <p>Promote a detected subscription from the Recurring page, or add one manually to see it on the calendar and in your cash-flow forecast.</p>
            <a asp-controller="Bills" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add Bill
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="pl-stat-card">
                    <div class="stat-label">Monthly Bills</div>
                    <div class="stat-value negative">@Model.MonthlyBillTotal.ToString("C")</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="pl-stat-card">
                    <div class="stat-label">Tracked</div>
                    <div class="stat-value">@(Model.ExpenseBills.Count + Model.IncomeBills.Count)</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="pl-stat-card">
                    <div class="stat-label">Overdue</div>
                    <div class="stat-value @(Model.OverdueCount > 0 ? "negative" : "")">@Model.OverdueCount</div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Forecast is not null)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-graph-down-arrow me-1"></i> Cash-Flow Forecast</h5>
                <div class="btn-group btn-group-sm" role="group" id="forecastRangeGroup">
                    <button type="button" class="btn btn-outline-secondary active" data-range="30">30d</button>
                    <button type="button" class="btn btn-outline-secondary" data-range="90">90d</button>
                </div>
            </div>
            <div class="card-body">
                @if (Model.Forecast.ZeroCrossingDate.HasValue)
                {
                    <div class="alert alert-warning mb-3">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Balance dips below $0 on <strong>@Model.Forecast.ZeroCrossingDate.Value.ToString("MMM d")</strong> at current pace.
                    </div>
                }
                <div class="pl-chart-container">
                    <canvas id="forecastChart" height="90"></canvas>
                </div>
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Upcoming Bills</h5>
        </div>
        @if (!Model.ExpenseBills.Any())
        {
            <div class="pl-empty-state"><p class="mb-0">No bills tracked.</p></div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Cadence</th>
                            <th class="text-end">Amount</th>
                            <th>Next Due</th>
                            <th>Source</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in Model.ExpenseBills.OrderBy(b => b.NextDue))
                        {
                            <tr>
                                <td>@bill.Name</td>
                                <td><span class="badge bg-secondary">@bill.Cadence.CadenceLabel()</span></td>
                                <td class="text-end">@bill.ExpectedAmount.ToString("C")</td>
                                <td>
                                    @bill.NextDue.ToString("MMM d, yyyy")
                                    @if (bill.IsOverdue())
                                    {
                                        <span class="badge bg-danger ms-1">Overdue</span>
                                    }
                                </td>
                                <td class="text-muted small">@bill.Source</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@bill.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <form asp-action="Dismiss" asp-route-id="@bill.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Dismiss</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @if (Model.IncomeBills.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Recurring Income</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Cadence</th>
                            <th class="text-end">Amount</th>
                            <th>Next Expected</th>
                            <th>Source</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in Model.IncomeBills.OrderBy(b => b.NextDue))
                        {
                            <tr>
                                <td>@bill.Name</td>
                                <td><span class="badge bg-secondary">@bill.Cadence.CadenceLabel()</span></td>
                                <td class="text-end text-positive">@bill.ExpectedAmount.ToString("C")</td>
                                <td>@bill.NextDue.ToString("MMM d, yyyy")</td>
                                <td class="text-muted small">@bill.Source</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@bill.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <form asp-action="Dismiss" asp-route-id="@bill.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Dismiss</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (Model.DismissedBills.Any())
    {
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0 text-muted">Dismissed</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Cadence</th>
                            <th class="text-end">Amount</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in Model.DismissedBills)
                        {
                            <tr class="text-muted">
                                <td>@bill.Name</td>
                                <td><span class="badge bg-secondary">@bill.Cadence.CadenceLabel()</span></td>
                                <td class="text-end">@bill.ExpectedAmount.ToString("C")</td>
                                <td class="text-end">
                                    <form asp-action="Delete" asp-route-id="@bill.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@section Scripts {
    @if (Model.Forecast is not null)
    {
        <script src="~/lib/chart.js/chart.umd.min.js"></script>
        <script>
            (function () {
                var c = PlChart.getColors();

                var allLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Forecast.Points.Select(p => p.Date.ToString("yyyy-MM-dd"))));
                var allData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Forecast.Points.Select(p => p.Balance)));

                function sliceRange(days) {
                    return { labels: allLabels.slice(0, days), data: allData.slice(0, days) };
                }

                var initial = sliceRange(30);

                var forecastChart = new Chart(document.getElementById('forecastChart'), {
                    type: 'line',
                    data: {
                        labels: initial.labels,
                        datasets: [{
                            label: 'Projected Balance',
                            data: initial.data,
                            borderColor: c.primary,
                            backgroundColor: 'transparent',
                            fill: false,
                            tension: 0.25,
                            pointRadius: 0,
                            pointHoverRadius: 5
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        return '$' + ctx.parsed.y.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                                    }
                                }
                            }
                        },
                        scales: {
                            x: PlChart.defaultScaleOptions(),
                            y: Object.assign(PlChart.defaultScaleOptions(), {
                                ticks: {
                                    color: c.textMuted,
                                    callback: function (value) { return '$' + value.toLocaleString(); }
                                }
                            })
                        }
                    }
                });

                document.getElementById('forecastRangeGroup').addEventListener('click', function (e) {
                    var btn = e.target.closest('[data-range]');
                    if (!btn) return;
                    this.querySelectorAll('.btn').forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    var days = parseInt(btn.dataset.range);
                    var sliced = sliceRange(days);
                    forecastChart.data.labels = sliced.labels;
                    forecastChart.data.datasets[0].data = sliced.data;
                    forecastChart.update();
                });

                document.addEventListener('themechanged', function () {
                    var nc = PlChart.getColors();
                    forecastChart.data.datasets[0].borderColor = nc.primary;
                    PlChart.applyTheme(forecastChart);
                });
            })();
        </script>
    }
}
