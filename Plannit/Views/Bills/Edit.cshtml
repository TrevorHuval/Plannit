@model Plannit.Models.ViewModels.BillFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Edit Bill" : "Add Bill";
}

<div class="page-header">
    <h1>@ViewData["Title"]</h1>
</div>

<div class="card" style="max-width: 560px;">
    <div class="card-body">
        <form asp-controller="Bills" asp-action="Save" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Netflix, Rent, Paycheck" required />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label asp-for="Cadence" class="form-label">Cadence</label>
                    <select asp-for="Cadence" class="form-select" asp-items="Html.GetEnumSelectList<Plannit.Services.RecurringCadence>()"></select>
                </div>
                <div class="col-sm-6">
                    <label asp-for="ExpectedAmount" class="form-label">Amount</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="ExpectedAmount" type="number" step="0.01" min="0" class="form-control" required />
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label asp-for="NextDue" class="form-label">Next Due</label>
                    <input asp-for="NextDue" type="date" class="form-control" required />
                </div>
                <div class="col-sm-6 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsIncome" class="form-check-input" type="checkbox" />
                        <label asp-for="IsIncome" class="form-check-label">This is income</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
