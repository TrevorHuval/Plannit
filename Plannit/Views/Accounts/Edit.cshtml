@model Plannit.Models.ViewModels.AccountFormViewModel
@{
    ViewData["Title"] = "Edit Account";
}

<div class="page-header">
    <h1>Edit Account</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    <input type="hidden" asp-for="RowVersion" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Type" class="form-label"></label>
                        <select asp-for="Type" asp-items="Html.GetEnumSelectList<Plannit.Models.Entities.AccountType>()" class="form-select" id="accountTypeSelect"></select>
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Institution" class="form-label"></label>
                        <input asp-for="Institution" class="form-control" />
                        <span asp-validation-for="Institution" class="text-danger"></span>
                    </div>

                    <div id="loanFields" class="d-none">
                        <hr />
                        <p class="pl-eyebrow mb-2">Loan Details</p>
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label asp-for="InterestRatePercent" class="form-label"></label>
                                <div class="input-group">
                                    <input asp-for="InterestRatePercent" type="number" step="0.01" min="0" max="100" class="form-control" />
                                    <span class="input-group-text">%</span>
                                </div>
                                <span asp-validation-for="InterestRatePercent" class="text-danger"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="MinimumPayment" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="MinimumPayment" type="number" step="0.01" min="0" class="form-control" />
                                </div>
                                <span asp-validation-for="MinimumPayment" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="OriginalPrincipal" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="OriginalPrincipal" type="number" step="0.01" min="0" class="form-control" />
                            </div>
                            <span asp-validation-for="OriginalPrincipal" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var select = document.getElementById('accountTypeSelect');
            var loanFields = document.getElementById('loanFields');
            var loanTypes = ['Loan', 'Mortgage'];
            function sync() {
                var text = select.options[select.selectedIndex].text;
                loanFields.classList.toggle('d-none', loanTypes.indexOf(text) === -1);
            }
            select.addEventListener('change', sync);
            sync();
        })();
    </script>
}
