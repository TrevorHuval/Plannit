@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Plannit</title>
    <script>
        (function(){var t=localStorage.getItem('pl-theme');if(!t)t=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';document.documentElement.setAttribute('data-bs-theme',t);})();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Plannit.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Mobile top bar -->
    <div class="pl-mobile-topbar">
        <button class="hamburger-btn" id="plHamburger" aria-label="Toggle navigation">
            <i class="bi bi-list"></i>
        </button>
        <a href="/" class="topbar-brand">Plannit</a>
    </div>

    <!-- Sidebar -->
    <nav class="pl-sidebar" id="plSidebar">
        <a asp-controller="Home" asp-action="Index" class="pl-sidebar-brand">
            <span class="brand-icon"><i class="bi bi-graph-up-arrow"></i></span>
            <span class="brand-text">Plannit</span>
        </a>

        <div class="pl-sidebar-nav">
            <a asp-controller="Home" asp-action="Index"
               class="pl-nav-link @(controller == "Home" ? "active" : "")">
                <i class="bi bi-speedometer2"></i>
                <span class="nav-label">Dashboard</span>
            </a>
            <a asp-controller="Accounts" asp-action="Index"
               class="pl-nav-link @(controller == "Accounts" && ViewContext.RouteData.Values["action"]?.ToString() != "Portfolio" ? "active" : "")">
                <i class="bi bi-wallet2"></i>
                <span class="nav-label">Accounts</span>
            </a>
            <a asp-controller="Transactions" asp-action="Index"
               class="pl-nav-link @(controller == "Transactions" ? "active" : "")">
                <i class="bi bi-arrow-left-right"></i>
                <span class="nav-label">Transactions</span>
            </a>
            <partial name="_SyncNavLink" />
            <a asp-controller="Reports" asp-action="Index"
               class="pl-nav-link @(controller == "Reports" ? "active" : "")">
                <i class="bi bi-bar-chart-line"></i>
                <span class="nav-label">Reports</span>
            </a>
            <a asp-controller="Accounts" asp-action="Portfolio"
               class="pl-nav-link @(controller == "Accounts" && ViewContext.RouteData.Values["action"]?.ToString() == "Portfolio" ? "active" : "")">
                <i class="bi bi-pie-chart"></i>
                <span class="nav-label">Portfolio</span>
            </a>
            <a asp-controller="Projections" asp-action="Index"
               class="pl-nav-link @(controller == "Projections" ? "active" : "")">
                <i class="bi bi-calculator"></i>
                <span class="nav-label">Projections</span>
            </a>
            <a asp-controller="Budgets" asp-action="Index"
               class="pl-nav-link @(controller == "Budgets" ? "active" : "")">
                <i class="bi bi-piggy-bank"></i>
                <span class="nav-label">Budgets</span>
            </a>
            <a asp-controller="Bills" asp-action="Index"
               class="pl-nav-link @(controller == "Bills" ? "active" : "")">
                <i class="bi bi-calendar-check"></i>
                <span class="nav-label">Bills</span>
            </a>
            <a asp-controller="Goals" asp-action="Index"
               class="pl-nav-link @(controller == "Goals" ? "active" : "")">
                <i class="bi bi-flag"></i>
                <span class="nav-label">Goals</span>
            </a>
            <a asp-controller="Debt" asp-action="Index"
               class="pl-nav-link @(controller == "Debt" ? "active" : "")">
                <i class="bi bi-graph-down"></i>
                <span class="nav-label">Debt</span>
            </a>
            <a asp-controller="Budgets" asp-action="Recurring"
               class="pl-nav-link @(controller == "Budgets" && ViewContext.RouteData.Values["action"]?.ToString() == "Recurring" ? "active" : "")">
                <i class="bi bi-arrow-repeat"></i>
                <span class="nav-label">Recurring</span>
            </a>
            <a asp-controller="Categories" asp-action="Index"
               class="pl-nav-link @(controller == "Categories" ? "active" : "")">
                <i class="bi bi-tags"></i>
                <span class="nav-label">Categories</span>
            </a>
            <partial name="_NotificationNavLink" />
            <a asp-controller="Settings" asp-action="Index"
               class="pl-nav-link @(controller == "Settings" ? "active" : "")">
                <i class="bi bi-gear"></i>
                <span class="nav-label">Settings</span>
            </a>
        </div>

        <div class="pl-sidebar-footer">
            <partial name="_LoginPartial" />
            <button type="button" class="pl-theme-btn" onclick="PlTheme.toggle()">
                <i id="themeIcon" class="bi bi-moon-stars"></i>
                <span class="theme-label" id="themeLabel">Dark Mode</span>
            </button>
            <button class="pl-collapse-btn" id="plCollapseBtn" title="Toggle sidebar">
                <i class="bi bi-chevron-bar-left"></i>
            </button>
        </div>
    </nav>

    <!-- Backdrop for mobile -->
    <div class="pl-sidebar-backdrop" id="plBackdrop"></div>

    <!-- Main content -->
    <div class="pl-main">
        <div class="pl-content-wrapper">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
