@model Plannit.Models.ViewModels.TransactionListViewModel
@{
    ViewData["Title"] = "Transactions";
    var currentUrl = Context.Request.Path + Context.Request.QueryString;

    var filterRouteValues = new Dictionary<string, string>();
    if (Model.AccountId.HasValue) filterRouteValues["accountId"] = Model.AccountId.Value.ToString();
    if (Model.CategoryId.HasValue) filterRouteValues["categoryId"] = Model.CategoryId.Value.ToString();
    if (Model.StartDate.HasValue) filterRouteValues["startDate"] = Model.StartDate.Value.ToString("yyyy-MM-dd");
    if (Model.EndDate.HasValue) filterRouteValues["endDate"] = Model.EndDate.Value.ToString("yyyy-MM-dd");
    if (!string.IsNullOrEmpty(Model.SearchText)) filterRouteValues["searchText"] = Model.SearchText;
}

<div class="page-header">
    <h1>Transactions</h1>
    <div class="page-actions">
        <form asp-controller="Categories" asp-action="RecategorizeUncategorized" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@currentUrl" />
            <button type="submit" class="btn btn-outline-success" title="Apply rules to uncategorized transactions">
                <i class="bi bi-lightning"></i> Auto-Categorize
            </button>
        </form>
        @if (Model.AiConfigured)
        {
            <form asp-controller="SmartCategorize" asp-action="Review" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="accountId" value="@Model.AccountId" />
                <button type="submit" class="btn btn-outline-primary" title="Use AI to propose categories for uncategorized transactions">
                    <i class="bi bi-stars"></i> Smart Categorize
                </button>
            </form>
        }
        <a asp-action="ExportCsv"
           asp-route-accountId="@Model.AccountId"
           asp-route-startDate="@(Model.StartDate?.ToString("yyyy-MM-dd"))"
           asp-route-endDate="@(Model.EndDate?.ToString("yyyy-MM-dd"))"
           asp-route-searchText="@Model.SearchText"
           asp-route-categoryId="@Model.CategoryId"
           class="btn btn-outline-secondary" title="Export filtered transactions to CSV">
            <i class="bi bi-download"></i> Export CSV
        </a>
        <a asp-action="Import" class="btn btn-outline-primary"><i class="bi bi-upload"></i> Import</a>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Transaction</a>
        @if (Model.AccountId.HasValue)
        {
            var selectedAccount = Model.Accounts.FirstOrDefault(a => a.Id == Model.AccountId);
            <div class="btn-group">
                <button type="button" class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-tools"></i> Account Tools
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <form asp-action="InvertAccountSigns" method="post"
                              onsubmit="return confirm('Flip the sign of every transaction in this account? Use this if a whole statement was imported with reversed polarity.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="accountId" value="@Model.AccountId" />
                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                            <button type="submit" class="dropdown-item">Invert all transaction signs</button>
                        </form>
                    </li>
                </ul>
            </div>
        }
    </div>
</div>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success alert-dismissible fade show">
        @message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="pl-filter-bar">
    <input type="hidden" name="pageSize" value="@Model.PageSize" />
    <div class="row g-3 align-items-end">
        <div class="col-md-2">
            <label for="accountId" class="form-label">Account</label>
            <select name="accountId" id="accountId" class="form-select form-select-sm">
                <option value="">All Accounts</option>
                @foreach (var a in Model.Accounts)
                {
                    <option value="@a.Id" selected="@(Model.AccountId == a.Id)">@a.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label for="categoryId" class="form-label">Category</label>
            <select name="categoryId" id="categoryId" class="form-select form-select-sm">
                <option value="">All Categories</option>
                <option value="-1" selected="@(Model.CategoryId == -1)">Uncategorized</option>
                @foreach (var c in Model.Categories)
                {
                    <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label for="startDate" class="form-label">From</label>
            <input type="date" name="startDate" id="startDate" class="form-control form-control-sm"
                   value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-2">
            <label for="endDate" class="form-label">To</label>
            <input type="date" name="endDate" id="endDate" class="form-control form-control-sm"
                   value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-2">
            <label for="searchText" class="form-label">Search</label>
            <input type="text" name="searchText" id="searchText" class="form-control form-control-sm"
                   value="@Model.SearchText" placeholder="Description..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-sm btn-primary w-100">Filter</button>
        </div>
    </div>
</form>

@if (!Model.Transactions.Any())
{
    <div class="card">
        <div class="pl-empty-state">
            <div class="empty-icon"><i class="bi bi-arrow-left-right"></i></div>
            <h4>No transactions found</h4>
            <p>Import a statement or add a transaction manually to get started.</p>
            <div class="d-flex gap-2 justify-content-center">
                <a asp-action="Import" class="btn btn-outline-primary"><i class="bi bi-upload"></i> Import</a>
                <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Transaction</a>
            </div>
        </div>
    </div>
}
else
{
    <div id="bulkBar" class="alert alert-info d-none mb-3">
        <span id="bulkCount">0</span> selected &mdash;
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#bulkCategoryModal">
            Set Category
        </button>
        <button type="button" class="btn btn-sm btn-outline-danger" onclick="bulkDelete()">
            Delete Selected
        </button>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="width:30px"><input type="checkbox" id="selectAll" title="Select all" /></th>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Account</th>
                        <th>Category</th>
                        <th class="text-end">Amount</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Transactions)
                    {
                        <tr>
                            <td><input type="checkbox" class="txn-check" value="@t.Id" /></td>
                            <td class="text-nowrap">@t.Date.ToString("MMM d, yyyy")</td>
                            <td>
                                @t.Description
                                @if (t.SplitGroupId.HasValue)
                                {
                                    <span class="badge bg-secondary ms-1" title="Part of a split transaction">Split</span>
                                }
                                @if (!string.IsNullOrEmpty(t.Notes))
                                {
                                    <i class="bi bi-sticky text-muted ms-1" title="@t.Notes"></i>
                                }
                            </td>
                            <td class="text-muted">@t.AccountName</td>
                            <td>
                                <form asp-controller="Categories" asp-action="SetTransactionCategory" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="transactionId" value="@t.Id" />
                                    <input type="hidden" name="returnUrl" value="@currentUrl" />
                                    <select name="categoryId" class="form-select form-select-sm" style="width:auto;display:inline-block"
                                            onchange="this.form.submit()">
                                        <option value="">--</option>
                                        @foreach (var c in Model.Categories)
                                        {
                                            <option value="@c.Id" selected="@(t.CategoryId == c.Id)">@c.Name</option>
                                        }
                                    </select>
                                </form>
                            </td>
                            <td class="text-end @(t.Amount >= 0 ? "text-positive" : "text-negative")">
                                @t.Amount.ToString("C")
                            </td>
                            <td class="text-end text-nowrap">
                                <button class="btn btn-sm btn-outline-secondary" title="Edit notes"
                                        data-bs-toggle="modal" data-bs-target="#notesModal"
                                        data-txn-id="@t.Id" data-txn-notes="@(t.Notes ?? "")">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <a asp-action="Split" asp-route-id="@t.Id" asp-route-returnUrl="@currentUrl" class="btn btn-sm btn-outline-secondary" title="Split transaction">
                                    <i class="bi bi-scissors"></i>
                                </a>
                                <a asp-controller="Categories" asp-action="CreateRuleFromTransaction"
                                   asp-route-transactionId="@t.Id" asp-route-returnUrl="@currentUrl"
                                   class="btn btn-sm btn-outline-secondary" title="Create categorization rule">Rule</a>
                                <a asp-action="Edit" asp-route-id="@t.Id" asp-route-returnUrl="@currentUrl" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form asp-action="Delete" asp-route-id="@t.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnUrl" value="@currentUrl" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete this transaction?')">Del</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_Pagination" model="@(new Plannit.Models.ViewModels.PaginationViewModel
    {
        Page = Model.Page,
        TotalPages = Model.TotalPages,
        TotalCount = Model.TotalCount,
        PageSize = Model.PageSize,
        Controller = "Transactions",
        Action = "Index",
        RouteValues = filterRouteValues,
        ItemNounSingular = "transaction",
        ItemNounPlural = "transactions"
    })" />
}

<!-- Notes Modal -->
<div class="modal fade" id="notesModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateNotes" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="notesModalTxnId" />
                <input type="hidden" name="returnUrl" value="@currentUrl" />
                <div class="modal-header">
                    <h5 class="modal-title">Edit Notes</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <textarea name="notes" id="notesModalText" class="form-control" rows="3" placeholder="Add a note..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bulk Set Category Modal -->
<div class="modal fade" id="bulkCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="BulkSetCategory" method="post" id="bulkCategoryForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@currentUrl" />
                <div id="bulkCategoryInputs"></div>
                <div class="modal-header">
                    <h5 class="modal-title">Set Category for Selected</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <select name="categoryId" class="form-select" required>
                        <option value="">Choose category...</option>
                        @foreach (var c in Model.Categories)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Apply</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bulk Delete Form (hidden) -->
<form asp-action="BulkDelete" method="post" id="bulkDeleteForm" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@currentUrl" />
    <div id="bulkDeleteInputs"></div>
</form>

@section Scripts {
<script>
(function() {
    var selectAll = document.getElementById('selectAll');
    var bulkBar = document.getElementById('bulkBar');
    var bulkCount = document.getElementById('bulkCount');

    function getChecked() {
        return document.querySelectorAll('.txn-check:checked');
    }

    function updateBulkBar() {
        var checked = getChecked();
        bulkCount.textContent = checked.length;
        bulkBar.classList.toggle('d-none', checked.length === 0);
    }

    if (selectAll) {
        selectAll.addEventListener('change', function() {
            document.querySelectorAll('.txn-check').forEach(function(cb) { cb.checked = selectAll.checked; });
            updateBulkBar();
        });
    }

    document.querySelectorAll('.txn-check').forEach(function(cb) {
        cb.addEventListener('change', updateBulkBar);
    });

    // Bulk category modal - populate hidden inputs
    var bulkCatModal = document.getElementById('bulkCategoryModal');
    if (bulkCatModal) {
        bulkCatModal.addEventListener('show.bs.modal', function() {
            var container = document.getElementById('bulkCategoryInputs');
            container.innerHTML = '';
            getChecked().forEach(function(cb) {
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'transactionIds';
                input.value = cb.value;
                container.appendChild(input);
            });
        });
    }

    // Bulk delete
    window.bulkDelete = function() {
        var checked = getChecked();
        if (checked.length === 0) return;
        if (!confirm('Delete ' + checked.length + ' selected transaction(s)?')) return;

        var container = document.getElementById('bulkDeleteInputs');
        container.innerHTML = '';
        checked.forEach(function(cb) {
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'transactionIds';
            input.value = cb.value;
            container.appendChild(input);
        });
        document.getElementById('bulkDeleteForm').submit();
    };

    // Notes modal
    var notesModal = document.getElementById('notesModal');
    if (notesModal) {
        notesModal.addEventListener('show.bs.modal', function(event) {
            var btn = event.relatedTarget;
            document.getElementById('notesModalTxnId').value = btn.getAttribute('data-txn-id');
            document.getElementById('notesModalText').value = btn.getAttribute('data-txn-notes');
        });
    }
})();
</script>
}
