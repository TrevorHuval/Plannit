@model Plannit.Models.ViewModels.SnapshotConfirmViewModel
@{
    ViewData["Title"] = "Confirm Balance Snapshot";
    var sourceLabel = Model.SourceType == "PdfStatement" ? "PDF statement" : "Positions export";
}

<div class="page-header">
    <h1>Confirm Balance Snapshot</h1>
</div>
<p class="text-muted">
    Importing @sourceLabel <strong>@Model.FileName</strong> into <strong>@Model.AccountName</strong>. No transactions are created — this only updates the account balance.
</p>

@if (!Model.BalanceFound)
{
    <div class="alert alert-warning">Could not automatically detect a balance in this file. Please enter it manually below.</div>
}
@if (!Model.DateFound)
{
    <div class="alert alert-warning">Could not automatically detect an as-of date. Defaulting to today — adjust if needed.</div>
}

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Snapshot Details</div>
            <div class="card-body">
                <form asp-action="ConfirmSnapshotImport" method="post">
                    <input type="hidden" asp-for="AccountId" />
                    <input type="hidden" asp-for="AccountName" />
                    <input type="hidden" asp-for="FileName" />
                    <input type="hidden" asp-for="TempFileId" />
                    <input type="hidden" asp-for="TempFileExtension" />
                    <input type="hidden" asp-for="SourceType" />

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="AsOfDate" class="form-label"></label>
                        <input asp-for="AsOfDate" type="date" class="form-control" />
                        <span asp-validation-for="AsOfDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Balance" class="form-label"></label>
                        <input asp-for="Balance" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Balance" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Snapshot</button>
                        <a asp-action="Import" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (Model.Positions.Any())
    {
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Positions</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Symbol</th>
                                    <th>Description</th>
                                    <th class="text-end">Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Positions)
                                {
                                    <tr>
                                        <td>@p.Symbol</td>
                                        <td>@p.Description</td>
                                        <td class="text-end">@p.Value.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="fw-bold">
                                    <td colspan="2">Total</td>
                                    <td class="text-end">@Model.Balance.ToString("C")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(Model.ExtractedText))
{
    <div class="card mt-4">
        <div class="card-header">Extracted Statement Text (for reference)</div>
        <div class="card-body">
            <pre class="mb-0" style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;">@Model.ExtractedText</pre>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
