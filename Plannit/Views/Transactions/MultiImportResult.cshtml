@model Plannit.Models.ViewModels.MultiImportResultViewModel
@{
    ViewData["Title"] = "Import Results";
}

<div class="page-header">
    <h1>Import Complete</h1>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">@Model.AccountName &mdash; @Model.FileResults.Count file(s)</h5>
    </div>
    <div class="card-body">
        <div class="row g-3 text-center">
            <div class="col">
                <div class="pl-figure fs-3">@Model.TotalRows</div>
                <div class="pl-eyebrow mt-1">Total Rows</div>
            </div>
            <div class="col">
                <div class="pl-figure fs-3 text-positive">@Model.TotalImported</div>
                <div class="pl-eyebrow mt-1">Imported</div>
            </div>
            <div class="col">
                <div class="pl-figure fs-3 text-warning">@Model.TotalDuplicates</div>
                <div class="pl-eyebrow mt-1">Duplicates Skipped</div>
            </div>
            <div class="col">
                <div class="pl-figure fs-3 text-negative">@Model.TotalErrors</div>
                <div class="pl-eyebrow mt-1">Errors</div>
            </div>
            <div class="col">
                <div class="pl-figure fs-3 text-info">@Model.CategorizedCount</div>
                <div class="pl-eyebrow mt-1">Auto-Categorized</div>
            </div>
            <div class="col">
                <div class="pl-figure fs-3 text-info">@Model.SnapshotsUpdated</div>
                <div class="pl-eyebrow mt-1">Snapshots Updated</div>
            </div>
        </div>
    </div>
</div>

@if (Model.ShowSnapshotNudge)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            Snapshot is older than these transactions
            @if (Model.NudgeLatestSnapshotDate.HasValue)
            {
                <text> (last updated @Model.NudgeLatestSnapshotDate.Value.ToString("MMM d, yyyy"))</text>
            }
            else
            {
                <text> (no snapshot on file yet)</text>
            }
            — update it?
        </div>
        <form asp-controller="Accounts" asp-action="AddSnapshot" method="post" class="d-flex gap-2 align-items-center flex-wrap">
            <input type="hidden" name="AccountId" value="@Model.NudgeAccountId" />
            <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Transactions", new { accountId = Model.NudgeAccountId })" />
            <input type="date" name="Date" class="form-control form-control-sm" value="@Model.NudgeNewestTransactionDate.ToString("yyyy-MM-dd")" style="width:160px" />
            <input type="number" step="0.01" name="Balance" class="form-control form-control-sm" placeholder="Balance" style="width:120px" required />
            <button type="submit" class="btn btn-sm btn-primary">Update Snapshot</button>
        </form>
    </div>
}

@if (Model.FileResults.Count > 1)
{
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Per-File Summary</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>File</th>
                            <th class="text-end">Total Rows</th>
                            <th class="text-end">Imported</th>
                            <th class="text-end">Duplicates</th>
                            <th class="text-end">Errors</th>
                            <th class="text-end">Snapshot</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in Model.FileResults)
                        {
                            <tr>
                                <td>@file.FileName</td>
                                @if (file.SnapshotOnly)
                                {
                                    <td class="text-end text-muted">&mdash;</td>
                                    <td class="text-end text-muted">&mdash;</td>
                                    <td class="text-end text-muted">&mdash;</td>
                                    <td class="text-end text-muted">&mdash;</td>
                                }
                                else
                                {
                                    <td class="text-end">@file.TotalRows</td>
                                    <td class="text-end text-positive">@file.ImportedCount</td>
                                    <td class="text-end text-warning">@file.DuplicateCount</td>
                                    <td class="text-end text-negative">@file.ErrorCount</td>
                                }
                                <td class="text-end">
                                    @if (file.SnapshotUpdated)
                                    {
                                        <span>@file.SnapshotBalance!.Value.ToString("C") as of @file.SnapshotDate!.Value.ToString("MMM d, yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">&mdash;</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else if (Model.FileResults.Count == 1 && Model.FileResults[0].SnapshotUpdated)
{
    var f = Model.FileResults[0];
    <div class="alert alert-success mb-4">
        Balance snapshot updated: @f.SnapshotBalance!.Value.ToString("C") as of @f.SnapshotDate!.Value.ToString("MMM d, yyyy")
    </div>
}

@foreach (var file in Model.FileResults.Where(f => f.Errors.Any()))
{
    <div class="card mb-4">
        <div class="card-header text-danger">Errors &mdash; @file.FileName</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Row</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var err in file.Errors)
                    {
                        <tr>
                            <td>@err.RowNumber</td>
                            <td>@err.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.AiConfigured && Model.UncategorizedRemaining > 0)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <i class="bi bi-stars"></i>
            @Model.UncategorizedRemaining transaction@(Model.UncategorizedRemaining == 1 ? "" : "s") @(Model.UncategorizedRemaining == 1 ? "is" : "are") still uncategorized. Let AI propose categories?
        </div>
        <form asp-controller="SmartCategorize" asp-action="Review" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="accountId" value="@Model.AccountId" />
            <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-stars"></i> Smart categorize @Model.UncategorizedRemaining remaining</button>
        </form>
    </div>
}

<div class="d-flex gap-2">
    <a asp-action="Index" class="btn btn-primary">View Transactions</a>
    <a asp-action="Import" class="btn btn-outline-secondary">Import More</a>
</div>
