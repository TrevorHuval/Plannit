@model Plannit.Models.ViewModels.MultiImportResultViewModel
@{
    ViewData["Title"] = "Import Results";
}

<div class="page-header">
    <h1>Import Complete</h1>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">@Model.AccountName &mdash; @Model.FileResults.Count file(s)</h5>
    </div>
    <div class="card-body">
        <div class="row g-3 text-center">
            <div class="col">
                <div class="fs-3 fw-bold">@Model.TotalRows</div>
                <div class="text-muted small">Total Rows</div>
            </div>
            <div class="col">
                <div class="fs-3 fw-bold text-positive">@Model.TotalImported</div>
                <div class="text-muted small">Imported</div>
            </div>
            <div class="col">
                <div class="fs-3 fw-bold" style="color: var(--pl-warning)">@Model.TotalDuplicates</div>
                <div class="text-muted small">Duplicates Skipped</div>
            </div>
            <div class="col">
                <div class="fs-3 fw-bold text-negative">@Model.TotalErrors</div>
                <div class="text-muted small">Errors</div>
            </div>
            <div class="col">
                <div class="fs-3 fw-bold" style="color: var(--pl-info)">@Model.CategorizedCount</div>
                <div class="text-muted small">Auto-Categorized</div>
            </div>
        </div>
    </div>
</div>

@if (Model.FileResults.Count > 1)
{
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Per-File Summary</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>File</th>
                            <th class="text-end">Total Rows</th>
                            <th class="text-end">Imported</th>
                            <th class="text-end">Duplicates</th>
                            <th class="text-end">Errors</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in Model.FileResults)
                        {
                            <tr>
                                <td>@file.FileName</td>
                                <td class="text-end">@file.TotalRows</td>
                                <td class="text-end text-positive">@file.ImportedCount</td>
                                <td class="text-end" style="color: var(--pl-warning)">@file.DuplicateCount</td>
                                <td class="text-end text-negative">@file.ErrorCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@foreach (var file in Model.FileResults.Where(f => f.Errors.Any()))
{
    <div class="card mb-4">
        <div class="card-header text-danger">Errors &mdash; @file.FileName</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Row</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var err in file.Errors)
                    {
                        <tr>
                            <td>@err.RowNumber</td>
                            <td>@err.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="d-flex gap-2">
    <a asp-action="Index" class="btn btn-primary">View Transactions</a>
    <a asp-action="Import" class="btn btn-outline-secondary">Import More</a>
</div>
