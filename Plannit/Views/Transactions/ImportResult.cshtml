@model Plannit.Models.ViewModels.ImportResultViewModel
@{
    ViewData["Title"] = "Import Results";
}

<h1>Import Complete</h1>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">@Model.FileName &rarr; @Model.AccountName</h5>
        <div class="row text-center mt-3">
            <div class="col-md-3">
                <div class="fs-3 fw-bold">@Model.TotalRows</div>
                <div class="text-muted">Total Rows</div>
            </div>
            <div class="col-md-3">
                <div class="fs-3 fw-bold text-success">@Model.ImportedCount</div>
                <div class="text-muted">Imported</div>
            </div>
            <div class="col-md-3">
                <div class="fs-3 fw-bold text-warning">@Model.DuplicateCount</div>
                <div class="text-muted">Duplicates Skipped</div>
            </div>
            <div class="col-md-3">
                <div class="fs-3 fw-bold text-danger">@Model.ErrorCount</div>
                <div class="text-muted">Errors</div>
            </div>
        </div>
    </div>
</div>

@if (Model.Errors.Any())
{
    <div class="card mb-4">
        <div class="card-header text-danger">Errors</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Row</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var err in Model.Errors)
                    {
                        <tr>
                            <td>@err.RowNumber</td>
                            <td>@err.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<a asp-action="Index" class="btn btn-primary">View Transactions</a>
<a asp-action="Import" class="btn btn-outline-secondary ms-2">Import Another</a>
