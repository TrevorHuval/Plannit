@model Plannit.Models.ViewModels.ImportResultViewModel
@{
    ViewData["Title"] = "Import Results";
}

<div class="page-header">
    <h1>Import Complete</h1>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">@Model.FileName &rarr; @Model.AccountName</h5>
    </div>
    <div class="card-body">
        <div class="row g-3 text-center">
            <div class="col">
                <div class="pl-figure fs-3">@Model.TotalRows</div>
                <div class="pl-eyebrow mt-1">Total Rows</div>
            </div>
            <div class="col">
                <div class="pl-figure fs-3 text-positive">@Model.ImportedCount</div>
                <div class="pl-eyebrow mt-1">Imported</div>
            </div>
            <div class="col">
                <div class="pl-figure fs-3 text-warning">@Model.DuplicateCount</div>
                <div class="pl-eyebrow mt-1">Duplicates Skipped</div>
            </div>
            <div class="col">
                <div class="pl-figure fs-3 text-negative">@Model.ErrorCount</div>
                <div class="pl-eyebrow mt-1">Errors</div>
            </div>
            <div class="col">
                <div class="pl-figure fs-3 text-info">@Model.CategorizedCount</div>
                <div class="pl-eyebrow mt-1">Auto-Categorized</div>
            </div>
        </div>
    </div>
</div>

@if (Model.Errors.Any())
{
    <div class="card mb-4">
        <div class="card-header text-danger">Errors</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Row</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var err in Model.Errors)
                    {
                        <tr>
                            <td>@err.RowNumber</td>
                            <td>@err.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="d-flex gap-2">
    <a asp-action="Index" class="btn btn-primary">View Transactions</a>
    <a asp-action="Import" class="btn btn-outline-secondary">Import Another</a>
</div>
