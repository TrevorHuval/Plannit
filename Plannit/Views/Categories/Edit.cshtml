@model Plannit.Models.ViewModels.CategoryFormViewModel
@{
    ViewData["Title"] = "Edit Category";
}

<h1>Edit Category</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ParentId" class="form-label">Parent Category</label>
                <select asp-for="ParentId" class="form-select">
                    <option value="">None (top-level)</option>
                    @foreach (var p in Model.AvailableParents)
                    {
                        <option value="@p.Id" selected="@(Model.ParentId == p.Id)">@p.Name</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
