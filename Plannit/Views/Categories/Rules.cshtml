@model Plannit.Models.ViewModels.CategoryRuleListViewModel
@{
    ViewData["Title"] = "Category Rules";
}

<div class="page-header">
    <h1>Category Rules</h1>
    <div class="page-actions">
        <a asp-action="TestRule" class="btn btn-outline-secondary"><i class="bi bi-search"></i> Test Rule</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Categories</a>
        <a asp-action="CreateRule" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Rule</a>
    </div>
</div>

@if (!Model.Rules.Any())
{
    <div class="card">
        <div class="pl-empty-state">
            <div class="empty-icon"><i class="bi bi-sliders"></i></div>
            <h4>No rules defined</h4>
            <p>Rules auto-categorize transactions during import.</p>
            <a asp-action="CreateRule" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Rule</a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Match Text</th>
                        <th>Match Type</th>
                        <th>Category</th>
                        <th class="text-center">Priority</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Rules)
                    {
                        <tr>
                            <td><code>@r.MatchText</code></td>
                            <td>@r.MatchType</td>
                            <td>@r.CategoryName</td>
                            <td class="text-center">
                                @r.Priority
                                <form asp-action="MoveRulePriority" method="post" class="d-inline ms-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <input type="hidden" name="moveUp" value="true" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary p-0 px-1" title="Move up">
                                        <i class="bi bi-arrow-up-short"></i>
                                    </button>
                                </form>
                                <form asp-action="MoveRulePriority" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <input type="hidden" name="moveUp" value="false" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary p-0 px-1" title="Move down">
                                        <i class="bi bi-arrow-down-short"></i>
                                    </button>
                                </form>
                            </td>
                            <td class="text-end">
                                <a asp-action="EditRule" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form asp-action="DeleteRule" asp-route-id="@r.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete this rule?')">Del</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
