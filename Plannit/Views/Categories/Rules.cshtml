@model Plannit.Models.ViewModels.CategoryRuleListViewModel
@{
    ViewData["Title"] = "Category Rules";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Category Rules</h1>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary me-2">Back to Categories</a>
        <a asp-action="CreateRule" class="btn btn-primary">Add Rule</a>
    </div>
</div>

@if (!Model.Rules.Any())
{
    <div class="alert alert-info">No rules defined. Rules auto-categorize transactions during import.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Match Text</th>
                    <th>Match Type</th>
                    <th>Category</th>
                    <th class="text-center">Priority</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Rules)
                {
                    <tr>
                        <td><code>@r.MatchText</code></td>
                        <td>@r.MatchType</td>
                        <td>@r.CategoryName</td>
                        <td class="text-center">@r.Priority</td>
                        <td class="text-end">
                            <a asp-action="EditRule" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <form asp-action="DeleteRule" asp-route-id="@r.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete this rule?')">Del</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
