@{
    ViewData["Title"] = "Settings";
}

<div class="page-header">
    <h1>Settings</h1>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-cloud-download"></i> Data Export</h5>
                <p class="card-text">Download a full backup of all your data as a JSON file. Includes accounts, snapshots, transactions, categories, rules, budgets, and projection scenarios.</p>
                <a asp-action="ExportJson" class="btn btn-primary"><i class="bi bi-download"></i> Export Full Backup (JSON)</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-clock-history"></i> Import History</h5>
                <p class="card-text">View and manage past file imports. Undo imports that went wrong by removing all transactions from a batch.</p>
                <a asp-action="Imports" class="btn btn-outline-primary"><i class="bi bi-list-ul"></i> View Import Batches</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-stars"></i> AI Categorization
                    @if (ViewBag.AiConfigured == true)
                    {
                        <span class="badge bg-success ms-1">Configured</span>
                    }
                </h5>
                <p class="card-text">Configure an AI provider to intelligently categorize your uncategorized transactions in one click. Conservative by design — unsure merchants are left untouched.</p>
                <a asp-action="Ai" class="btn btn-outline-primary"><i class="bi bi-gear"></i> Configure AI Provider</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-bell"></i> Notifications</h5>
                <p class="card-text">Choose which alerts (budget overages, upcoming bills, low forecast balance, unusual transactions, stale accounts) generate a notification, and whether they're also emailed.</p>
                <a asp-action="Notifications" class="btn btn-outline-primary"><i class="bi bi-gear"></i> Configure Notifications</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-shield-check"></i> Audit Log</h5>
                <p class="card-text">Review sensitive actions on your account — logins, exports, bulk deletes, import undo, and AI settings changes.</p>
                <a asp-action="AuditLog" class="btn btn-outline-primary"><i class="bi bi-list-ul"></i> View Audit Log</a>
            </div>
        </div>
    </div>
</div>
