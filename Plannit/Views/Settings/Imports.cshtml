@model List<Plannit.Models.Entities.ImportBatch>
@{
    ViewData["Title"] = "Import History";
}

<div class="page-header">
    <h1>Import History</h1>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Settings</a>
    </div>
</div>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success alert-dismissible fade show">
        @message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card">
        <div class="pl-empty-state">
            <div class="empty-icon"><i class="bi bi-inbox"></i></div>
            <h4>No imports yet</h4>
            <p>When you import CSV or OFX files, they will appear here.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>File</th>
                        <th>Account</th>
                        <th>Date</th>
                        <th class="text-center">Rows</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var batch in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="ImportDetail" asp-route-id="@batch.Id">@batch.FileName</a>
                            </td>
                            <td>@batch.Account.Name</td>
                            <td>@batch.ImportedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                            <td class="text-center">@batch.RowCount</td>
                            <td class="text-end">
                                <form asp-action="UndoImport" asp-route-id="@batch.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Undo this import? This will delete all @batch.RowCount transactions from this batch.')">
                                        <i class="bi bi-arrow-counterclockwise"></i> Undo
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
