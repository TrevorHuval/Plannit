@model Plannit.Models.ViewModels.BudgetIndexViewModel
@{
    ViewData["Title"] = "Budget Tracking";
    var prevMonth = Model.Month.AddMonths(-1);
    var nextMonth = Model.Month.AddMonths(1);
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Budget &mdash; @Model.MonthLabel</h1>
    <a asp-action="Settings" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-gear"></i> Settings
    </a>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="btn-group" role="group">
        <a asp-action="Index" asp-route-year="@prevMonth.Year" asp-route-month="@prevMonth.Month"
           class="btn btn-sm btn-outline-secondary"><i class="bi bi-chevron-left"></i> Prev</a>
        <a asp-action="Index" asp-route-year="@nextMonth.Year" asp-route-month="@nextMonth.Month"
           class="btn btn-sm btn-outline-secondary">Next <i class="bi bi-chevron-right"></i></a>
    </div>
    @if (Model.Statuses.Any())
    {
        <span class="text-muted">
            Spent @Model.TotalSpent.ToString("C") of @Model.TotalBudgeted.ToString("C") budgeted
        </span>
    }
</div>

@if (!Model.Statuses.Any())
{
    <div class="card">
        <div class="pl-empty-state">
            <div class="empty-icon"><i class="bi bi-piggy-bank"></i></div>
            <h4>No budgets set</h4>
            <p>Set monthly spending limits for your categories to start tracking.</p>
            <a asp-action="Settings" class="btn btn-primary">
                <i class="bi bi-gear"></i> Set Up Budgets
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var status in Model.Statuses)
        {
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0">@status.Budget.Category.Name</h6>
                            <span class="badge bg-@status.StatusClass">@status.StatusLabel</span>
                        </div>
                        <div class="progress mb-2" style="height: 8px;">
                            @{
                                var pctClamped = Math.Min(status.Percentage * 100, 100);
                            }
                            <div class="progress-bar bg-@status.StatusClass" role="progressbar"
                                 style="width: @pctClamped.ToString("F0")%"
                                 aria-valuenow="@pctClamped.ToString("F0")" aria-valuemin="0" aria-valuemax="100">
                            </div>
                        </div>
                        <div class="d-flex justify-content-between text-muted small">
                            <span>@status.Spent.ToString("C") spent</span>
                            <span>@status.Budget.MonthlyAmount.ToString("C") limit</span>
                        </div>
                        @if (status.Remaining < 0)
                        {
                            <div class="text-danger small mt-1">
                                <i class="bi bi-exclamation-triangle"></i> @Math.Abs(status.Remaining).ToString("C") over budget
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
