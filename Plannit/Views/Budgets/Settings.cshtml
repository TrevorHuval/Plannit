@model Plannit.Models.ViewModels.BudgetSettingsViewModel
@{
    ViewData["Title"] = "Budget Settings";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Budget Settings</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Budget
    </a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Monthly Budget by Category</h5>
    </div>
    <div class="card-body">
        <p class="text-muted mb-3">Set a monthly spending limit for each category. Leave blank or set to 0 to remove a budget.</p>
        <form method="post" asp-action="SaveBudgets">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th style="width: 200px;">Monthly Limit</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Categories)
                        {
                            <tr>
                                <td class="align-middle">@row.CategoryName</td>
                                <td>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">$</span>
                                        <input type="number" step="0.01" min="0"
                                               name="amounts[@row.CategoryId]"
                                               class="form-control form-control-sm"
                                               value="@(row.MonthlyAmount?.ToString("F2") ?? "")"
                                               placeholder="0.00" />
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Save Budgets
                </button>
            </div>
        </form>
    </div>
</div>
