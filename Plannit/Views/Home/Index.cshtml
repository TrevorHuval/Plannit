@model Plannit.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h1>Dashboard</h1>
</div>

@if (!Model.HasAccounts)
{
    <div class="card">
        <div class="pl-empty-state">
            <div class="empty-icon"><i class="bi bi-wallet2"></i></div>
            <h4>Welcome to Plannit!</h4>
            <p>Add your first account to start tracking your net worth and expenses.</p>
            <a asp-controller="Accounts" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add Account
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="pl-stat-card">
                    <div class="stat-label">Net Worth</div>
                    <div class="stat-value @(Model.NetWorth >= 0 ? "positive" : "negative")">
                        @Model.NetWorth.ToString("C")
                    </div>
                </div>
            </div>
        </div>
        @foreach (var total in Model.TypeTotals)
        {
            <div class="col-md-4">
                <div class="card">
                    <div class="pl-stat-card">
                        <div class="stat-label">@total.TypeDisplayName</div>
                        <div class="stat-value @(total.IsLiability ? "negative" : "")">
                            @if (total.IsLiability)
                            {
                                @:−@total.Total.ToString("C")
                            }
                            else
                            {
                                @total.Total.ToString("C")
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.NetWorthHistory.Count >= 2)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Net Worth Over Time</h5>
            </div>
            <div class="card-body">
                <div class="pl-chart-container">
                    <canvas id="netWorthChart" height="100"></canvas>
                </div>
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        @if (Model.BudgetAlerts.Any())
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-piggy-bank me-1"></i> Budget Status</h5>
                        <a asp-controller="Budgets" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
                    </div>
                    <div class="card-body">
                        @foreach (var status in Model.BudgetAlerts)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-medium">@status.Budget.Category.Name</span>
                                    <span class="badge bg-@status.StatusClass">@status.StatusLabel</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    @{
                                        var pct = Math.Min(status.Percentage * 100, 100);
                                    }
                                    <div class="progress-bar bg-@status.StatusClass" style="width: @pct.ToString("F0")%"></div>
                                </div>
                                <div class="d-flex justify-content-between text-muted small mt-1">
                                    <span>@status.Spent.ToString("C")</span>
                                    <span>@status.Budget.MonthlyAmount.ToString("C")</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        @if (Model.UpcomingRecurring.Any())
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-arrow-repeat me-1"></i> Upcoming Recurring</h5>
                        <a asp-controller="Budgets" asp-action="Recurring" class="btn btn-sm btn-outline-secondary">View All</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                    <th>Expected</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.UpcomingRecurring)
                                {
                                    <tr>
                                        <td>@item.Description</td>
                                        <td class="text-end">@item.AverageAmount.ToString("C")</td>
                                        <td>@item.NextExpected.ToString("MMM d")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    @if (Model.HasAccounts && Model.NetWorthHistory.Count >= 2)
    {
        <script src="~/lib/chart.js/chart.umd.min.js"></script>
        <script>
            (function () {
                var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NetWorthHistory.Select(h => h.Date)));
                var data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NetWorthHistory.Select(h => h.NetWorth)));
                var c = PlChart.getColors();

                var chart = new Chart(document.getElementById('netWorthChart'), {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Net Worth',
                            data: data,
                            borderColor: c.positive,
                            backgroundColor: 'transparent',
                            fill: true,
                            tension: 0.3,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        return '$' + ctx.parsed.y.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                                    }
                                }
                            }
                        },
                        scales: {
                            x: PlChart.defaultScaleOptions(),
                            y: Object.assign(PlChart.defaultScaleOptions(), {
                                ticks: {
                                    color: c.textMuted,
                                    callback: function (value) { return '$' + value.toLocaleString(); }
                                }
                            })
                        }
                    }
                });

                document.addEventListener('themechanged', function () {
                    var nc = PlChart.getColors();
                    chart.data.datasets[0].borderColor = nc.positive;
                    PlChart.applyTheme(chart);
                });
            })();
        </script>
    }
}
