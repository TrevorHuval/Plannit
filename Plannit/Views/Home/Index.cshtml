@model Plannit.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h1>Dashboard</h1>
    @if (Model.HasAccounts)
    {
        <div class="page-actions">
            <a asp-controller="Accounts" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-plus-circle me-1"></i>Add Snapshot
            </a>
            <a asp-controller="Transactions" asp-action="Import" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-upload me-1"></i>Import Statements
            </a>
            <a asp-controller="Transactions" asp-action="Create" class="btn btn-sm btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Add Transaction
            </a>
        </div>
    }
</div>

@if (!Model.HasAccounts)
{
    <div class="card">
        <div class="pl-empty-state">
            <div class="empty-icon"><i class="bi bi-wallet2"></i></div>
            <h4>Welcome to Plannit!</h4>
            <p>Add your first account to start tracking your net worth and expenses.</p>
            <a asp-controller="Accounts" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add Account
            </a>
        </div>
    </div>
}
else
{
    <!-- Net Worth hero + secondary metrics -->
    <div class="row g-3 mb-4">
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="pl-hero-card">
                    <div class="stat-label">Net Worth</div>
                    <div class="stat-value @(Model.NetWorth >= 0 ? "positive" : "negative")">
                        @Model.NetWorth.ToString("C")
                    </div>
                    <div class="stat-deltas mt-1">
                        @if (Model.NetWorth1MonthAgo != 0)
                        {
                            var delta1M = Model.NetWorth - Model.NetWorth1MonthAgo;
                            var pct1M = Model.NetWorth1MonthDelta;
                            <span class="stat-delta @(delta1M >= 0 ? "delta-positive" : "delta-negative")">
                                @(delta1M >= 0 ? "▲" : "▼") @Math.Abs(pct1M).ToString("P1")
                                <span class="delta-label">1M</span>
                            </span>
                        }
                        @if (Model.NetWorth12MonthsAgo != 0)
                        {
                            var delta12M = Model.NetWorth - Model.NetWorth12MonthsAgo;
                            var pct12M = Model.NetWorth12MonthDelta;
                            <span class="stat-delta @(delta12M >= 0 ? "delta-positive" : "delta-negative")">
                                @(delta12M >= 0 ? "▲" : "▼") @Math.Abs(pct12M).ToString("P1")
                                <span class="delta-label">12M</span>
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="card h-100">
                <div class="pl-stat-card">
                    <div class="stat-label">This Month</div>
                    <div class="stat-monthly-summary">
                        <div class="monthly-row">
                            <span class="monthly-label">Income</span>
                            <span class="text-positive fw-medium">@Model.ThisMonthIncome.ToString("C")</span>
                        </div>
                        <div class="monthly-row">
                            <span class="monthly-label">Spending</span>
                            <span class="text-negative fw-medium">@Model.ThisMonthSpending.ToString("C")</span>
                        </div>
                        @if (Model.ThisMonthBudgetTotal > 0)
                        {
                            <div class="monthly-row">
                                <span class="monthly-label">Budget</span>
                                <span class="fw-medium">@Model.ThisMonthBudgetTotal.ToString("C")</span>
                            </div>
                        }
                        <hr class="my-1" />
                        <div class="monthly-row">
                            <span class="monthly-label fw-medium">Net</span>
                            @{
                                var net = Model.ThisMonthIncome - Model.ThisMonthSpending;
                            }
                            <span class="fw-semibold @(net >= 0 ? "text-positive" : "text-negative")">
                                @net.ToString("C")
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card h-100">
                <div class="pl-stat-card">
                    <div class="stat-label">Asset Allocation</div>
                    <div class="pl-chart-container" style="max-height: 140px;">
                        <canvas id="allocationChart"></canvas>
                    </div>
                    <div class="mt-2">
                        @foreach (var t in Model.TypeTotals)
                        {
                            <div class="d-flex justify-content-between small">
                                <span>
                                    @t.TypeDisplayName
                                    @if (t.IsLiability)
                                    {
                                        <span class="badge bg-negative-subtle text-negative">Debt</span>
                                    }
                                </span>
                                <span class="@(t.IsLiability ? "text-negative" : "")">
                                    @(t.IsLiability ? "−" : "")@t.Total.ToString("C")
                                </span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Net Worth Chart with range selector -->
    @if (Model.NetWorthHistory.Count >= 2)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Net Worth Over Time</h5>
                <div class="btn-group btn-group-sm" role="group" id="chartRangeGroup">
                    <button type="button" class="btn btn-outline-secondary" data-range="3">3M</button>
                    <button type="button" class="btn btn-outline-secondary" data-range="12">1Y</button>
                    <button type="button" class="btn btn-outline-secondary active" data-range="0">All</button>
                </div>
            </div>
            <div class="card-body">
                <div class="pl-chart-container">
                    <canvas id="netWorthChart" height="100"></canvas>
                </div>
            </div>
        </div>
    }

    <!-- Top Categories + Budget Alerts row -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-pie-chart me-1"></i> Top Spending</h5>
                    <a asp-controller="Reports" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
                </div>
                <div class="card-body">
                    @if (Model.TopCategories.Any())
                    {
                        @foreach (var cat in Model.TopCategories)
                        {
                            var pctOfTotal = Model.ThisMonthSpending > 0
                                ? (cat.Total / Model.ThisMonthSpending * 100)
                                : 0;
                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-medium small">@cat.CategoryName</span>
                                    <span class="small text-muted">@cat.Total.ToString("C")</span>
                                </div>
                                <div class="progress" style="height: 5px;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width: @pctOfTotal.ToString("F0")%; background-color: var(--pl-primary);">
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-muted text-center py-3">
                            <i class="bi bi-inbox"></i> No spending this month
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (Model.BudgetAlerts.Any())
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-piggy-bank me-1"></i> Budget Status</h5>
                        <a asp-controller="Budgets" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
                    </div>
                    <div class="card-body">
                        @foreach (var status in Model.BudgetAlerts)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-medium">@status.Budget.Category.Name</span>
                                    <span class="badge bg-@status.StatusClass">@status.StatusLabel</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    @{
                                        var pct = Math.Min(status.Percentage * 100, 100);
                                    }
                                    <div class="progress-bar bg-@status.StatusClass" style="width: @pct.ToString("F0")%"></div>
                                </div>
                                <div class="d-flex justify-content-between text-muted small mt-1">
                                    <span>@status.Spent.ToString("C")</span>
                                    <span>@status.Budget.MonthlyAmount.ToString("C")</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else if (!Model.TopCategories.Any())
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <div class="text-muted text-center py-3">
                            <i class="bi bi-piggy-bank" style="font-size: 1.5rem;"></i>
                            <p class="mb-2 mt-2">No budgets set up yet</p>
                            <a asp-controller="Budgets" asp-action="Settings" class="btn btn-sm btn-outline-primary">Set Up Budgets</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Recent Transactions -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-clock-history me-1"></i> Recent Transactions</h5>
            <a asp-controller="Transactions" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
        </div>
        @if (Model.RecentTransactions.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Description</th>
                            <th>Account</th>
                            <th>Category</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var currentUrl = Context.Request.Path + Context.Request.QueryString;
                        }
                        @foreach (var t in Model.RecentTransactions)
                        {
                            <tr>
                                <td class="text-nowrap">@t.Date.ToString("MMM d")</td>
                                <td>@t.Description</td>
                                <td class="text-muted small">@t.AccountName</td>
                                <td>
                                    <form asp-controller="Categories" asp-action="CategorizeTransaction" method="post" class="d-inline">
                                        <input type="hidden" name="transactionId" value="@t.Id" />
                                        <input type="hidden" name="returnUrl" value="@currentUrl" />
                                        <select name="categoryId" class="form-select form-select-sm" style="width:auto;display:inline-block;min-width:120px;"
                                                onchange="this.form.submit()">
                                            <option value="">--</option>
                                            @foreach (var c in Model.Categories)
                                            {
                                                <option value="@c.Id" selected="@(t.CategoryId == c.Id)">@c.Name</option>
                                            }
                                        </select>
                                    </form>
                                </td>
                                <td class="text-end fw-medium @(t.Amount >= 0 ? "text-positive" : "text-negative")">
                                    @t.Amount.ToString("C")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-body">
                <div class="text-muted text-center py-3">
                    <i class="bi bi-inbox"></i> No transactions yet.
                    <a asp-controller="Transactions" asp-action="Import">Import statements</a> to get started.
                </div>
            </div>
        }
    </div>

    <!-- Upcoming Bills + Stale Accounts row -->
    <div class="row g-3 mb-4">
        @if (Model.UpcomingBills.Any())
        {
            <div class="@(Model.StaleAccounts.Any() ? "col-md-6" : "col-12")">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-calendar-check me-1"></i> Upcoming Bills</h5>
                        <a asp-controller="Bills" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th class="text-end">Amount</th>
                                    <th>Due</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var bill in Model.UpcomingBills)
                                {
                                    <tr>
                                        <td>
                                            @bill.Name
                                            @if (bill.IsOverdue())
                                            {
                                                <span class="badge bg-danger ms-1">Overdue</span>
                                            }
                                        </td>
                                        <td class="text-end">@bill.ExpectedAmount.ToString("C")</td>
                                        <td>@bill.NextDue.ToString("MMM d")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        @if (Model.StaleAccounts.Any())
        {
            <div class="@(Model.UpcomingBills.Any() ? "col-md-6" : "col-12")">
                <div class="card h-100">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-1"></i> Needs Attention</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var stale in Model.StaleAccounts)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2 p-2 rounded" style="background: var(--pl-surface-alt);">
                                <div>
                                    <span class="fw-medium">@stale.AccountName</span>
                                    <span class="text-muted small ms-2">last updated @stale.DaysSinceUpdate days ago</span>
                                </div>
                                <a asp-controller="Accounts" asp-action="Details" asp-route-id="@stale.AccountId"
                                   class="btn btn-sm btn-outline-primary">Update</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    @if (Model.HasAccounts)
    {
        <script src="~/lib/chart.js/chart.umd.min.js"></script>
        <script>
            (function () {
                var c = PlChart.getColors();

                // Asset allocation doughnut
                @if (Model.TypeTotals.Any())
                {
                    var allocLabels = Model.TypeTotals.Select(t => t.TypeDisplayName).ToList();
                    var allocData = Model.TypeTotals.Select(t => t.Total).ToList();
                    <text>
                    var allocChart = new Chart(document.getElementById('allocationChart'), {
                        type: 'doughnut',
                        data: {
                            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allocLabels)),
                            datasets: [{
                                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allocData)),
                                backgroundColor: PlChart.palette.slice(0, @allocLabels.Count),
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            cutout: '60%',
                            plugins: {
                                legend: {
                                    position: 'right',
                                    labels: {
                                        color: c.textMuted,
                                        boxWidth: 12,
                                        padding: 8,
                                        font: { size: 11 }
                                    }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function (ctx) {
                                            return ctx.label + ': $' + ctx.parsed.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                                        }
                                    }
                                }
                            }
                        }
                    });
                    </text>
                }

                // Net worth line chart with range filtering
                @if (Model.NetWorthHistory.Count >= 2)
                {
                    <text>
                    var allLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NetWorthHistory.Select(h => h.Date)));
                    var allData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NetWorthHistory.Select(h => h.NetWorth)));

                    function filterByMonths(months) {
                        if (months === 0) return { labels: allLabels, data: allData };
                        var cutoff = new Date();
                        cutoff.setMonth(cutoff.getMonth() - months);
                        var cutoffStr = cutoff.toISOString().substring(0, 10);
                        var filteredLabels = [];
                        var filteredData = [];
                        for (var i = 0; i < allLabels.length; i++) {
                            if (allLabels[i] >= cutoffStr) {
                                filteredLabels.push(allLabels[i]);
                                filteredData.push(allData[i]);
                            }
                        }
                        return { labels: filteredLabels, data: filteredData };
                    }

                    var netWorthChart = new Chart(document.getElementById('netWorthChart'), {
                        type: 'line',
                        data: {
                            labels: allLabels,
                            datasets: [{
                                label: 'Net Worth',
                                data: allData,
                                borderColor: c.positive,
                                backgroundColor: 'transparent',
                                fill: true,
                                tension: 0.3,
                                pointRadius: 3,
                                pointHoverRadius: 6
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    callbacks: {
                                        label: function (ctx) {
                                            return '$' + ctx.parsed.y.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: PlChart.defaultScaleOptions(),
                                y: Object.assign(PlChart.defaultScaleOptions(), {
                                    ticks: {
                                        color: c.textMuted,
                                        callback: function (value) { return '$' + value.toLocaleString(); }
                                    }
                                })
                            }
                        }
                    });

                    document.getElementById('chartRangeGroup').addEventListener('click', function (e) {
                        var btn = e.target.closest('[data-range]');
                        if (!btn) return;
                        this.querySelectorAll('.btn').forEach(function (b) { b.classList.remove('active'); });
                        btn.classList.add('active');
                        var months = parseInt(btn.dataset.range);
                        var filtered = filterByMonths(months);
                        netWorthChart.data.labels = filtered.labels;
                        netWorthChart.data.datasets[0].data = filtered.data;
                        netWorthChart.update();
                    });
                    </text>
                }

                // Theme change handler
                document.addEventListener('themechanged', function () {
                    var nc = PlChart.getColors();
                    @if (Model.NetWorthHistory.Count >= 2)
                    {
                        <text>
                        netWorthChart.data.datasets[0].borderColor = nc.positive;
                        PlChart.applyTheme(netWorthChart);
                        </text>
                    }
                    @if (Model.TypeTotals.Any())
                    {
                        <text>
                        allocChart.options.plugins.legend.labels.color = nc.textMuted;
                        allocChart.update('none');
                        </text>
                    }
                });
            })();
        </script>
    }
}
